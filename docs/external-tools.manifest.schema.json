{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "external-tools manifest",
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "display_name", "repo", "section", "artifact_type", "upstream_publishes_skill", "summary", "triggers", "install_pointer"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "display_name": { "type": "string" },
          "repo": { "type": "string" },
          "section": { "type": "string" },
          "artifact_type": { "type": "string" },
          "upstream_publishes_skill": { "type": "boolean" },
          "summary": { "type": "string" },
          "triggers": { "type": "array", "items": { "type": "string" } },
          "install_pointer": { "type": "string" },
          "compliance_notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
