# CI dashboard config. Copy to .env, fill in, then run ./serve.sh.
#
# GITLAB_URL: the URL where your self-hosted GitLab is reachable.
GITLAB_URL=https://git.your.tld

# GITLAB_TOKEN: a Personal Access Token with `read_api` scope.
# Create at: User settings → Access Tokens → New
GITLAB_TOKEN=glpat-replace-me

# Bind config (optional)
# SEEME_CI_PORT=7778
# SEEME_CI_HOST=127.0.0.1
