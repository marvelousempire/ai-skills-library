# Homelab console config — copy to .env, fill in, then run `make start` or
# `make ui`. Console works without any of these set (it'll just show "down"
# pills for the unreachable services), but the more it can probe, the more
# useful the dashboard is.

# ─── GitLab CE ────────────────────────────────────────────────
# Where your self-hosted GitLab is reachable. Leave commented if you
# haven't booted GitLab yet (the console will still load).
# GITLAB_URL=https://git.your-tailnet.ts.net

# Personal Access Token (User → Settings → Access Tokens) with scope: read_api
# Token never leaves the console server.
# GITLAB_TOKEN=glpat-replace-me

# ─── Other services (defaults usually fine) ───────────────────
# SEEME_URL=http://localhost:7777
# OLLAMA_HOST=http://localhost:11434
# CI_DASHBOARD_URL=http://localhost:7778

# ─── Server bind ──────────────────────────────────────────────
# CONSOLE_PORT=7779
# CONSOLE_HOST=127.0.0.1
