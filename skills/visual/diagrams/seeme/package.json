{
  "name": "seeme",
  "version": "0.1.0",
  "description": "AI visual interpreter — turn any text into a Unicode box-and-arrow diagram in the ascii-flow-diagrams style. Defaults to Ollama; supports OpenAI, Anthropic, Gemini, Perplexity.",
  "type": "module",
  "bin": {
    "seeme": "./bin/seeme"
  },
  "scripts": {
    "start": "node src/cli.ts",
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ai": "^4.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/perplexity": "^1.0.0",
    "ollama-ai-provider": "^1.0.0",
    "cac": "^6.7.14",
    "clipboardy": "^4.0.0",
    "yoctocolors": "^2.1.1",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=22.6.0"
  }
}
