{
  "name": "seeme",
  "version": "1.0.0",
  "description": "AI visual interpreter — turn any text into a Unicode box-and-arrow diagram in the ascii-flow-diagrams style. Defaults to Ollama; supports OpenAI, Anthropic, Gemini, Perplexity.",
  "type": "module",
  "bin": {
    "seeme": "./bin/seeme",
    "seeme-mcp": "./bin/seeme-mcp"
  },
  "scripts": {
    "start": "node src/cli.ts",
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "check": "npm run typecheck && npm run test",
    "docker:build": "docker build -f Dockerfile -t seeme:latest ..",
    "docker:run": "docker run --rm -it -p 7777:7777 -v seeme-data:/home/seeme/.seeme --env-file .env seeme:latest",
    "docker:up": "docker compose up -d && echo 'SEEME UI: http://localhost:7777'",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f seeme"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/perplexity": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^4.0.0",
    "cac": "^6.7.14",
    "clipboardy": "^4.0.0",
    "dotenv": "^16.4.5",
    "ollama-ai-provider": "^1.0.0",
    "yoctocolors": "^2.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.6.0"
  }
}
