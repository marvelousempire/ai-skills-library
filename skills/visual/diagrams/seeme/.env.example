# SEEME — environment variables
#
# At least one of these is required, OR run Ollama locally (no key needed).
# Uncomment whichever provider(s) you want to use.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...

# Override Ollama host (default: http://localhost:11434):
# OLLAMA_HOST=http://localhost:11434

# Default provider (auto-detect if unset). One of:
#   ollama | anthropic | openai | gemini | perplexity
# SEEME_PROVIDER=ollama

# Default model (provider-specific). Examples:
#   ollama:     llama3.1, qwen2.5-coder, mistral
#   anthropic:  claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5
#   openai:     gpt-4o, gpt-4o-mini
#   gemini:     gemini-2.0-flash, gemini-1.5-pro
#   perplexity: sonar-large, sonar-pro
# SEEME_MODEL=llama3.1

# Opt in to Anthropic's 1-hour prompt cache (requires beta access).
# Adds the extended-cache-ttl-2025-04-11 beta header and sets ttl: '1h' on
# the system-prompt cache_control. Default (unset) uses the standard 5-min cache.
# SEEME_LONG_CACHE=1
