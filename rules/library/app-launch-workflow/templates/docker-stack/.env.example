# ────────────────────────────────────────────────────────────────────────────
# .env.example — copied to .env on first `./go` if .env doesn't exist.
# Edit .env (gitignored), not this file.
# ────────────────────────────────────────────────────────────────────────────

# ─── Database (Postgres + pgvector) ─────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# ─── HTTPS reverse proxy ────────────────────────────────────────────────────
# Localhost dev: leave as `localhost`. Caddy uses internal TLS.
# Production: set to your real hostname (e.g. myapp.example.com). Caddy will
# auto-fetch Let's Encrypt certs on first request.
CADDY_HOST=localhost

# ─── Optional API keys (uncomment + set if/when you wire them up) ──────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# VOYAGE_API_KEY=

# ─── Optional: where the watcher service looks for uploads on the host ────
# Default `./data/incoming/`. Override to a different folder if you want
# the watcher to pick up files from e.g. ~/Downloads or an iCloud-synced dir.
# WATCH_DIR_HOST=./data/incoming
